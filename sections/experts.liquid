<section class="experts" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="experts-head">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
    </div>
    <div class="experts-grid">
      {% for block in section.blocks %}
        <div class="expert-card">
          <blockquote>"{{ block.settings.quote }}"</blockquote>
          <div class="by">
            <span class="avt">{{ block.settings.initials }}</span>
            <div class="who"><strong>{{ block.settings.name }}</strong><span class="role">{{ block.settings.role }}</span></div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Expert quotes",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Endorsed by experts",
      "label": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Expert quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "initials",
          "default": "AM",
          "label": "Initials"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Expert quotes"
    }
  ]
}
{% endschema %}