<section class="pillars">
  <div class="wrap-wide">
    <div class="pillars-head">
      <span class="eyebrow">The four-pillar stack</span>
      <h2>What your body needs — <em>in one sachet.</em></h2>
      <p>Built across four systems. Every dose labelled. Nothing hidden behind a "proprietary blend."</p>
    </div>
    <div class="pillars-grid">
      <div class="pillar-card">
        <div class="pillar-num">01 / 04</div>
        <span class="pillar-ico"><svg viewBox="0 0 24 24"><use href="#i-leaf"/></svg></span>
        <h4>Minerals &amp; Electrolytes</h4>
        <ul class="pillar-ings">
          <li><span class="ing">9× Bamboo Salt</span><span class="dose">750mg Na</span></li>
          <li><span class="ing">Potassium Citrate</span><span class="dose">200mg</span></li>
          <li><span class="ing">Magnesium Citrate</span><span class="dose">50mg</span></li>
        </ul>
      </div>
      <div class="pillar-card">
        <div class="pillar-num">02 / 04</div>
        <span class="pillar-ico"><svg viewBox="0 0 24 24"><use href="#i-brain"/></svg></span>
        <h4>Energy + Focus</h4>
        <ul class="pillar-ings">
          <li><span class="ing">Cognizin® Citicoline</span><span class="dose">250mg</span></li>
          <li><span class="ing">L-Tyrosine</span><span class="dose">500mg</span></li>
          <li><span class="ing">Rhodiola Rosea</span><span class="dose">200mg</span></li>
        </ul>
      </div>
      <div class="pillar-card">
        <div class="pillar-num">03 / 04</div>
        <span class="pillar-ico"><svg viewBox="0 0 24 24"><use href="#i-bolt"/></svg></span>
        <h4>Physical Performance</h4>
        <ul class="pillar-ings">
          <li><span class="ing">Taurine</span><span class="dose">500mg</span></li>
          <li><span class="ing">ALCAR</span><span class="dose">300mg</span></li>
        </ul>
      </div>
      <div class="pillar-card">
        <div class="pillar-num">04 / 04</div>
        <span class="pillar-ico"><svg viewBox="0 0 24 24"><use href="#i-shield"/></svg></span>
        <h4>Recovery &amp; Antioxidants</h4>
        <ul class="pillar-ings">
          <li><span class="ing">Hydroxyl ions</span><span class="dose">Whole</span></li>
          <li><span class="ing">70+ trace minerals</span><span class="dose">70+</span></li>
        </ul>
      </div>
    </div>
    <p class="pillars-foot">14+ ingredients · 4 supplement types · 1 sachet · No caffeine · No prop blends</p>
  </div>
</section>
{% schema %}
{ "name": "Four-pillar ingredients", "presets": [{ "name": "Four-pillar ingredients" }] }
{% endschema %}
