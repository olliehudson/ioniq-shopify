<section class="body-bench" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="body-bench-head">
      <div><span class="eyebrow ember">{{ section.settings.eyebrow }}</span><h2>{{ section.settings.heading }}</h2></div>
      <p>{{ section.settings.copy }}</p>
    </div>
    <div class="body-bench-grid">
      {% for block in section.blocks %}
        <div class="body-bench-card">
          <div class="ico"><svg><use href="#i-{{ block.settings.icon }}"/></svg></div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.body }}</p>
          <div class="stat"><b>{{ block.settings.stat }}</b>{{ block.settings.stat_label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Whole-body benefits",
  "settings": [
    { "type": "text", "id": "eyebrow", "default": "Whole-body benefits" },
    { "type": "inline_richtext", "id": "heading" },
    { "type": "textarea", "id": "copy" }
  ],
  "blocks": [{
    "type": "card", "name": "Benefit",
    "settings": [
      { "type": "select", "id": "icon", "options": [
        { "value": "heart", "label": "Heart" }, { "value": "brain", "label": "Brain" }, { "value": "muscle", "label": "Muscle" },
        { "value": "bolt", "label": "Bolt" }, { "value": "moon", "label": "Moon" }, { "value": "drop", "label": "Drop" }
      ], "default": "heart" },
      { "type": "text", "id": "title" },
      { "type": "textarea", "id": "body" },
      { "type": "text", "id": "stat" },
      { "type": "text", "id": "stat_label" }
    ]
  }],
  "max_blocks": 6,
  "presets": [{ "name": "Whole-body benefits" }]
}
{% endschema %}