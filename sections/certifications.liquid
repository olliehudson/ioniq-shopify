<section class="certs" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="certs-head"><h3>{{ section.settings.heading }}</h3><p>{{ section.settings.copy }}</p></div>
    <div class="certs-grid">
      {% for block in section.blocks %}
        <div class="cert">
          <div class="ico"><svg><use href="#i-{{ block.settings.icon }}"/></svg></div>
          <h5>{{ block.settings.title }}</h5>
          <p>{{ block.settings.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Certifications row",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Tested. Verified. <em>Athlete-safe.</em>",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy"
    }
  ],
  "blocks": [
    {
      "type": "cert",
      "name": "Certification",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "options": [
            {
              "value": "shield",
              "label": "Shield"
            },
            {
              "value": "leaf",
              "label": "Leaf"
            },
            {
              "value": "verified",
              "label": "Verified"
            },
            {
              "value": "check",
              "label": "Check"
            }
          ],
          "default": "shield",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Certifications"
    }
  ]
}
{% endschema %}