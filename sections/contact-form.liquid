<section class="contact-body" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="contact-grid">
      {% form 'contact', class: 'form-card' %}
        <h2>{{ section.settings.heading }}</h2>
        <p class="lede">{{ section.settings.lede }}</p>
        {% if form.posted_successfully? %}<p style="color:var(--green-deep);">Message received — we'll get back within 24 hours.</p>{% endif %}
        <div class="form-row two">
          <div><label>First name</label><input type="text" name="contact[first_name]" required></div>
          <div><label>Last name</label><input type="text" name="contact[last_name]" required></div>
        </div>
        <div class="form-row two">
          <div><label>Email</label><input type="email" name="contact[email]" required></div>
          <div><label>Order number (optional)</label><input type="text" name="contact[order_number]"></div>
        </div>
        <div class="form-row">
          <label>What's this about?</label>
          <select name="contact[topic]" required>
            <option value="">Select a topic</option>
            {% for block in section.blocks %}{% if block.type == 'topic' %}
              <option>{{ block.settings.text }}</option>
            {% endif %}{% endfor %}
          </select>
        </div>
        <div class="form-row">
          <label>Your message</label>
          <textarea name="contact[body]" required></textarea>
          <span class="hint">We reply within 24 hours, Mon–Fri.</span>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-lg">Send message</button>
          <span class="small">Or email <a href="mailto:{{ section.settings.support_email }}" style="color:var(--green-deep);text-decoration:underline;">{{ section.settings.support_email }}</a></span>
        </div>
      {% endform %}

      <div class="contact-side">
        {% for block in section.blocks %}{% if block.type == 'side_card' %}
          <div class="side-card{% if block.settings.is_green %} is-green{% endif %}">
            <h3>{{ block.settings.heading }}</h3>
            <a class="line" href="{{ block.settings.link }}">{{ block.settings.link_text }}</a>
            <p class="sub">{{ block.settings.subtext }}</p>
          </div>
        {% endif %}{% endfor %}
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "richtext", "id": "heading", "default": "<h2>Send us a <em>message.</em></h2>" },
    { "type": "textarea", "id": "lede" },
    { "type": "text", "id": "support_email", "default": "hello@drinkioniq.com" }
  ],
  "blocks": [
    { "type": "topic", "name": "Topic option", "settings": [{ "type": "text", "id": "text", "default": "An order — shipping / refund / damage" }] },
    { "type": "side_card", "name": "Sidebar card", "settings": [
      { "type": "checkbox", "id": "is_green", "default": false },
      { "type": "text", "id": "heading", "default": "General support" },
      { "type": "text", "id": "link_text" },
      { "type": "url", "id": "link" },
      { "type": "textarea", "id": "subtext" }
    ]}
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}