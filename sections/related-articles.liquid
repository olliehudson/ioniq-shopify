<section class="related" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="related-head">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.cta_url != blank %}<a href="{{ section.settings.cta_url }}" class="btn btn-ghost btn-sm">{{ section.settings.cta_text }}</a>{% endif %}
    </div>
    <div class="related-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.url }}" class="related-card">
          <div class="img">{% if block.settings.image != blank %}<img src="{{ block.settings.image | image_url: width: 1200 }}" alt="">{% endif %}</div>
          <span class="meta">{{ block.settings.meta }}</span>
          <h4>{{ block.settings.title }}</h4>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Related articles",
  "settings": [
    { "type": "inline_richtext", "id": "heading", "default": "More from <em>the Journal</em>" },
    { "type": "text", "id": "cta_text", "default": "All articles →" },
    { "type": "url", "id": "cta_url" }
  ],
  "blocks": [{
    "type": "article", "name": "Article",
    "settings": [
      { "type": "image_picker", "id": "image" },
      { "type": "text", "id": "meta" },
      { "type": "text", "id": "title" },
      { "type": "url", "id": "url" }
    ]
  }],
  "presets": [{ "name": "Related articles" }]
}
{% endschema %}