<section class="contact-hero" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="contact-hero-inner">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.copy }}</p>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Contact hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "default": "Get in touch" },
    { "type": "richtext", "id": "heading", "default": "<h1>We're <em>here</em> when you need us.</h1>" },
    { "type": "textarea", "id": "copy" }
  ],
  "presets": [{ "name": "Contact hero" }]
}
{% endschema %}