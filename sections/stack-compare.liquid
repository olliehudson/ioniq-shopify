<section class="stack" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="stack-head">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
    </div>
    {% if section.settings.image != blank %}
      <div class="stack-figure">
        <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.image.alt | escape }}">
      </div>
    {% endif %}
    {% if section.settings.foot != blank %}<p class="stack-foot">{{ section.settings.foot }}</p>{% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Stack comparison",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "One ritual replaces five",
      "label": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Same coverage. One product. <em>$168 less.</em>",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Comparison image"
    },
    {
      "type": "inline_richtext",
      "id": "foot",
      "default": "Same coverage. One product. <strong>$168 less per month.</strong>",
      "label": "Foot"
    }
  ],
  "presets": [
    {
      "name": "Stack compare"
    }
  ]
}
{% endschema %}