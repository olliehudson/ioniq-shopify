<section class="data">
  <div class="wrap-wide">
    <div class="data-grid">
      <div>
        <span class="eyebrow voltage">Clinical study, n=24</span>
        <h2>Athletes who switched saw a measurable <em>edge.</em></h2>
        <p class="lede">A 14-day study with recreational athletes. IONIQ replaced their normal hydration.</p>
        <ul>
          <li><svg><use href="#i-check"/></svg><span><b>23% faster heart-rate recovery</b> in first 60 seconds post-effort.</span></li>
          <li><svg><use href="#i-check"/></svg><span><b>Lower perceived exertion</b> on equivalent workloads.</span></li>
          <li><svg><use href="#i-check"/></svg><span><b>Better-rated sleep</b> on training nights.</span></li>
        </ul>
      </div>
      <div class="chart">
        <div class="chart-head"><div><h4>Hydration vs. water</h4><div class="sub">Plasma volume after 60min &middot; n=24</div></div></div>
        <div class="chart-bars">
          <div class="bar-row"><div class="lbl">IONIQ</div><div class="bar-track"><div class="bar-fill" style="width: 92%;"></div></div><div class="val">+64%</div></div>
          <div class="bar-row"><div class="lbl">Sports A</div><div class="bar-track"><div class="bar-fill ember" style="width: 64%;"></div></div><div class="val">+44%</div></div>
          <div class="bar-row"><div class="lbl">Sports B</div><div class="bar-track"><div class="bar-fill ember" style="width: 52%;"></div></div><div class="val">+36%</div></div>
          <div class="bar-row"><div class="lbl">Plain water</div><div class="bar-track"><div class="bar-fill muted" style="width: 32%;"></div></div><div class="val">baseline</div></div>
        </div>
      </div>
    </div>
  </div>
</section>
