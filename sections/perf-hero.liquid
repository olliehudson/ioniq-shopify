<section class="perf-hero" id="section-{{ section.id }}">
  <span class="vrail">{{ section.settings.vrail }}</span>
  <div class="wrap-wide" style="position:relative;z-index:3;">
    <div class="perf-hero-eyebrow"><span class="blink"></span>{{ section.settings.eyebrow }}</div>
    <div class="perf-hero-grid">
      <div>
        <h1>{{ section.settings.heading }}</h1>
        <p class="perf-hero-lede">{{ section.settings.lede }}</p>
        <div class="perf-hero-ctas">
          <a href="{{ section.settings.cta_url | default: '/products/ioniq-morning-ritual' }}" class="btn btn-voltage btn-lg">{{ section.settings.cta_text }}</a>
          <span class="note">{{ section.settings.cta_note }}</span>
        </div>
      </div>
      <div class="perf-hero-side">
        {% if section.settings.image != blank %}
          <div class="perf-hero-product"><img src="{{ section.settings.image | image_url: width: 1000 }}" alt=""></div>
        {% endif %}
        <div class="perf-hero-tiles">
          {% for block in section.blocks %}
            <div class="perf-hero-tile"><div class="num">{{ block.settings.value }}</div><div class="lbl">{{ block.settings.label }}</div></div>
          {% endfor %}
        </div>
      </div>
    </div>
    {% if section.settings.ticker_1 != blank %}
      <div class="perf-hero-ticker">
        <div class="cell">{{ section.settings.ticker_1 }}</div>
        <div class="cell">{{ section.settings.ticker_2 }}</div>
        <div class="cell">{{ section.settings.ticker_3 }}</div>
        <div class="cell">{{ section.settings.ticker_4 }}</div>
      </div>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Performance hero",
  "settings": [
    {
      "type": "text",
      "id": "vrail",
      "default": "IONIQ Performance · for serious athletes",
      "label": "Vrail"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Trusted by athletes who can't afford an off day",
      "label": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Train harder. Recover faster. <em>Win the third set.</em>",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "lede",
      "default": "The performance electrolyte built for athletes who train daily and compete often. 1,000mg of clinical-dose electrolytes, 9× fire-roasted bamboo salt and a full nootropic stack — so you cramp less, recover quicker, and stay sharp when it counts. No sugar. No caffeine. No banned substances.",
      "label": "Lede"
    },
    {
      "type": "text",
      "id": "cta_text",
      "default": "See the formula — Shop IONIQ",
      "label": "Cta Text"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Cta Url"
    },
    {
      "type": "text",
      "id": "cta_note",
      "default": "Informed Sport certified · free shipping · cancel anytime",
      "label": "Cta Note"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "ticker_1",
      "default": "Total electrolytes <b>1,000 mg</b>",
      "label": "Ticker 1"
    },
    {
      "type": "text",
      "id": "ticker_2",
      "default": "Sugar / Caffeine <b>0 g / 0 mg</b>",
      "label": "Ticker 2"
    },
    {
      "type": "text",
      "id": "ticker_3",
      "default": "vs water absorption <b>+64%</b>",
      "label": "Ticker 3"
    },
    {
      "type": "text",
      "id": "ticker_4",
      "default": "Cost / serving <b>$1.40</b>",
      "label": "Ticker 4"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Spec tile",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "default": "750mg",
          "label": "Value"
        },
        {
          "type": "text",
          "id": "label",
          "default": "Sodium",
          "label": "Label"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Performance hero"
    }
  ]
}
{% endschema %}