<section class="story-hero">
  <div class="wrap-wide">
    <div class="story-hero-grid">
      <div>
        <span class="eyebrow">Our story</span>
        <h1>From the <em>tennis court</em> to the cabinet.</h1>
        <p class="lede">IONIQ was built by an ex-professional tennis player who couldn't find a hydration product that actually worked. So he made one.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary btn-lg">Shop IONIQ — $42/mo</a>
      </div>
      <div class="story-hero-img">
        <img src="{{ 'oliver-tennis.jpg' | asset_url }}" alt="Oliver Hudson, IONIQ founder">
      </div>
    </div>
  </div>
</section>
{% schema %}
{ "name": "Story hero", "presets": [{ "name": "Story hero" }] }
{% endschema %}