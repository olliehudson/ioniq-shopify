<section class="protocol-use" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="pu-head">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
    </div>
    <div class="pu-grid">
      {% for block in section.blocks %}
        <div class="pu-card">
          <div class="when"><span class="no">{{ block.settings.number }}</span><span class="lbl">{{ block.settings.timing }}</span></div>
          <h4>{{ block.settings.title }}</h4>
          <p class="quote">"{{ block.settings.quote }}"</p>
          <p>{{ block.settings.body }}</p>
          <div class="spec"><b>{{ block.settings.spec_bold }}</b> · {{ block.settings.spec_text }}</div>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.foot_title != blank %}
      <div class="pu-foot">
        <div>
          <div class="tt">{{ section.settings.foot_title }}</div>
          <div class="ss">{{ section.settings.foot_sub }}</div>
        </div>
        {% if section.settings.cta_url != blank %}<a href="{{ section.settings.cta_url }}" class="btn btn-primary btn-sm">{{ section.settings.cta_text }}</a>{% endif %}
      </div>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Athlete protocol",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "When to take, how many",
      "label": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "The athlete <em>protocol.</em>",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy"
    },
    {
      "type": "text",
      "id": "foot_title",
      "default": "Most members settle into 1 morning + 1 pre-workout",
      "label": "Foot Title"
    },
    {
      "type": "text",
      "id": "foot_sub",
      "label": "Foot Sub"
    },
    {
      "type": "text",
      "id": "cta_text",
      "default": "Subscribe — $42/mo →",
      "label": "Cta Text"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Cta Url"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Protocol step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "default": "01",
          "label": "Number"
        },
        {
          "type": "text",
          "id": "timing",
          "default": "30–45 min before",
          "label": "Timing"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Pre-training",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "quote",
          "default": "Take 1 before training.",
          "label": "Quote"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body"
        },
        {
          "type": "text",
          "id": "spec_bold",
          "default": "1 sachet",
          "label": "Spec Bold"
        },
        {
          "type": "text",
          "id": "spec_text",
          "default": "500ml cold water",
          "label": "Spec Text"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Athlete protocol"
    }
  ]
}
{% endschema %}