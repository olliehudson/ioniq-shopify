<section class="certs" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="certs-head"><h3>{{ section.settings.heading }}</h3><p>{{ section.settings.copy }}</p></div>
    <div class="certs-grid">
      {% for block in section.blocks %}
        <div class="cert">
          <div class="ico"><svg><use href="#i-{{ block.settings.icon }}"/></svg></div>
          <h5>{{ block.settings.title }}</h5>
          <p>{{ block.settings.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Certifications row",
  "settings": [
    { "type": "richtext", "id": "heading", "default": "<h3>Tested. Verified. <em>Athlete-safe.</em></h3>" },
    { "type": "textarea", "id": "copy" }
  ],
  "blocks": [{
    "type": "cert", "name": "Certification",
    "settings": [
      { "type": "select", "id": "icon", "options": [
        { "value": "shield", "label": "Shield" }, { "value": "leaf", "label": "Leaf" },
        { "value": "verified", "label": "Verified" }, { "value": "check", "label": "Check" }
      ], "default": "shield" },
      { "type": "text", "id": "title" },
      { "type": "textarea", "id": "body" }
    ]
  }],
  "max_blocks": 5,
  "presets": [{ "name": "Certifications" }]
}
{% endschema %}