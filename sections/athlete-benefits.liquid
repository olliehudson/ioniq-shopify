<section class="athlete-benefits" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="ab-head">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
    </div>
    <div class="ab-grid">
      {% for block in section.blocks %}
        <div class="ab-card">
          <div class="ico"><svg><use href="#i-{{ block.settings.icon }}"/></svg></div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.body }}</p>
          <div class="ctx"><b>{{ block.settings.stat }}</b>{{ block.settings.stat_label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Athlete benefits",
  "settings": [
    { "type": "text", "id": "eyebrow", "default": "Built for sports" },
    { "type": "inline_richtext", "id": "heading", "default": "The four things <em>athletes</em> feel first." },
    { "type": "textarea", "id": "copy" }
  ],
  "blocks": [{
    "type": "card", "name": "Benefit card",
    "settings": [
      { "type": "select", "id": "icon", "options": [
        { "value": "run", "label": "Run" }, { "value": "drop", "label": "Drop" },
        { "value": "muscle", "label": "Muscle" }, { "value": "brain", "label": "Brain" },
        { "value": "bolt", "label": "Bolt" }, { "value": "shield", "label": "Shield" }
      ], "default": "run" },
      { "type": "text", "id": "title", "default": "Endurance improvement" },
      { "type": "textarea", "id": "body" },
      { "type": "text", "id": "stat", "default": "+9%" },
      { "type": "text", "id": "stat_label", "default": "time to exhaustion" }
    ]
  }],
  "max_blocks": 4,
  "presets": [{ "name": "Athlete benefits" }]
}
{% endschema %}