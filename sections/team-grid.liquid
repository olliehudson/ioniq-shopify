<section class="team" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="team-head">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
    </div>
    <div class="team-grid">
      {% for block in section.blocks %}
        <div class="team-card">
          <div class="pic"{% if block.settings.image != blank %} style="background-image:url({{ block.settings.image | image_url: width: 800 }});background-size:cover;"{% endif %}>
            {% if block.settings.image == blank %}<div class="ph"></div>{% endif %}
          </div>
          <div class="body">
            <div class="role">{{ block.settings.role }}</div>
            <h4>{{ block.settings.name }}</h4>
            <p>{{ block.settings.bio }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Team grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy"
    }
  ],
  "blocks": [
    {
      "type": "person",
      "name": "Team member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Bio"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team grid"
    }
  ]
}
{% endschema %}