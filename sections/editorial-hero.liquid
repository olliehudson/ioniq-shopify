<section class="ed-pre"><div class="wrap-wide"><a href="{{ section.settings.back_url }}" class="ed-back">{{ section.settings.back_text }}</a></div></section>
<section class="ed-hero" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="ed-hero-inner">
      <div class="ed-meta-top">
        <span class="num">{{ section.settings.num }}</span><span class="dot"></span>
        <span>{{ section.settings.category }}</span><span class="dot"></span>
        <span>{{ section.settings.read_time }}</span>
      </div>
      <h1>{{ section.settings.heading }}</h1>
      <p class="ed-deck">{{ section.settings.deck }}</p>
      <div class="ed-byline">
        <div class="item"><span class="lbl">Words by</span><span class="val">{{ section.settings.author }}</span></div>
        <div class="item"><span class="lbl">Photography</span><span class="val">{{ section.settings.photographer }}</span></div>
        <div class="item"><span class="lbl">Published</span><span class="val">{{ section.settings.published }}</span></div>
      </div>
    </div>
  </div>
</section>
{% if section.settings.hero_image != blank %}
<div class="wrap-wide">
  <figure class="ed-hero-img">
    <img src="{{ section.settings.hero_image | image_url: width: 2400 }}" alt="">
    {% if section.settings.caption != blank %}<span class="ed-hero-cap">{{ section.settings.caption }}</span>{% endif %}
  </figure>
</div>
{% endif %}
{% schema %}
{
  "name": "Editorial article hero",
  "settings": [
    { "type": "text", "id": "back_url", "default": "/blogs/journal" },
    { "type": "text", "id": "back_text", "default": "Back to the Journal" },
    { "type": "text", "id": "num", "default": "N°01" },
    { "type": "text", "id": "category", "default": "Science" },
    { "type": "text", "id": "read_time", "default": "8 min read" },
    { "type": "richtext", "id": "heading" },
    { "type": "textarea", "id": "deck" },
    { "type": "text", "id": "author", "default": "Dr. Anya Mehta" },
    { "type": "text", "id": "photographer", "default": "Joren Cull" },
    { "type": "text", "id": "published", "default": "17 May, 2026" },
    { "type": "image_picker", "id": "hero_image" },
    { "type": "richtext", "id": "caption" }
  ],
  "presets": [{ "name": "Editorial hero" }]
}
{% endschema %}