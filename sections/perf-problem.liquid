<section class="perf-problem" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="head">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
    </div>
    <div class="compare-row">
      <div class="compare-card compare-them">
        <span class="tag">{{ section.settings.them_tag }}</span>
        <h3>{{ section.settings.them_heading }}</h3>
        <ul>{% for block in section.blocks %}{% if block.type == 'them' %}<li><svg><use href="#i-x"/></svg>{{ block.settings.text }}</li>{% endif %}{% endfor %}</ul>
      </div>
      <div class="compare-card compare-us">
        <span class="tag">{{ section.settings.us_tag }}</span>
        <h3>{{ section.settings.us_heading }}</h3>
        <ul>{% for block in section.blocks %}{% if block.type == 'us' %}<li><svg><use href="#i-check"/></svg>{{ block.settings.text }}</li>{% endif %}{% endfor %}</ul>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Compare them vs us",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Most sports drinks are <em>sugar.</em>",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy"
    },
    {
      "type": "text",
      "id": "them_tag",
      "default": "The other guys",
      "label": "Them Tag"
    },
    {
      "type": "inline_richtext",
      "id": "them_heading",
      "default": "A sugar bomb in disguise.",
      "label": "Them Heading"
    },
    {
      "type": "text",
      "id": "us_tag",
      "default": "IONIQ Performance",
      "label": "Us Tag"
    },
    {
      "type": "inline_richtext",
      "id": "us_heading",
      "default": "Clinical-dose fuel.",
      "label": "Us Heading"
    }
  ],
  "blocks": [
    {
      "type": "them",
      "name": "Their bullet (with X)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "us",
      "name": "Our bullet (with check)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Compare them vs us"
    }
  ]
}
{% endschema %}