<section class="channels">
  <div class="wrap-wide">
    <div class="channels-head">
      <span class="eyebrow">Other ways to reach us</span>
      <h2>Pick a <em>channel.</em></h2>
      <p>Some questions are faster on socials. Some are easier by email. Use what works for you.</p>
    </div>
    <div class="channels-grid">
      <a href="mailto:hello@drinkioniq.com" class="channel">
        <div class="ico"><svg><use href="#i-mail"/></svg></div>
        <h4>Email</h4>
        <p>Reply within 24 hours, Mon-Fri.</p>
        <span class="ln">hello@drinkioniq.com &rarr;</span>
      </a>
      <a href="#" class="channel">
        <div class="ico"><svg><use href="#i-chat"/></svg></div>
        <h4>Live chat</h4>
        <p>9am-6pm ET, Mon-Fri. Bottom-right corner.</p>
        <span class="ln">Open chat &rarr;</span>
      </a>
      <a href="#" class="channel">
        <div class="ico"><svg><use href="#i-press"/></svg></div>
        <h4>Instagram DM</h4>
        <p>We respond to DMs daily - often faster than email.</p>
        <span class="ln">@drinkioniq &rarr;</span>
      </a>
      <a href="#" class="channel">
        <div class="ico"><svg><use href="#i-store"/></svg></div>
        <h4>Stockist?</h4>
        <p>Find IONIQ in 200+ studios, clinics and shops worldwide.</p>
        <span class="ln">Find a stockist &rarr;</span>
      </a>
    </div>
  </div>
</section>
{% schema %}
{ "name": "Contact channels", "presets": [{ "name": "Contact channels" }] }
{% endschema %}