<section class="perf-faq" id="section-{{ section.id }}">
  <div class="wrap-wide">
    <div class="perf-faq-grid">
      <div>
        <span class="eyebrow voltage">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.copy }}</p>
      </div>
      <div>
        {% for block in section.blocks %}
          <details>
            <summary>{{ block.settings.question }}</summary>
            <div class="body-text">{{ block.settings.answer }}</div>
          </details>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Performance FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Questions, answered",
      "label": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy"
    }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Q&A",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "inline_richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Performance FAQ"
    }
  ]
}
{% endschema %}