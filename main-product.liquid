{% if product == blank or product == empty %}<section class="pdp"><div class="wrap-wide" style="padding:80px 0;text-align:center;"><h2 style="font-family:var(--font-display);font-weight:900;font-size:48px;text-transform:uppercase;margin-bottom:16px;">Product not loaded</h2><a href="/products/ioniq-morning-ritual" class="btn btn-primary btn-lg">View IONIQ product →</a></div></section>{% else %}<section class="pdp">
  <div class="wrap-wide">
    <div class="pdp-grid">

      <!-- GALLERY -->
      <div class="gallery">
        <div class="gallery-main">
          <div class="badge-best"><div>#1<br>Best<br>Selling</div></div>
          {% if product.featured_image %}
            <img id="hero-img-{{ section.id }}" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | escape }}">
          {% else %}
            <img id="hero-img-{{ section.id }}" src="{{ 'product-hero.webp' | asset_url }}" alt="IONIQ">
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="gallery-thumbs">
            {% for img in product.images limit: 4 %}
              <button class="thumb{% if forloop.first %} is-active{% endif %}" data-img="{{ img | image_url: width: 1200 }}">
                <img src="{{ img | image_url: width: 200 }}" alt="">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- BUY -->
      <div class="buy">
        <div class="buy-rating">
          <span class="stars">{% for i in (1..5) %}<svg width="14" height="14"><use href="#i-star"/></svg>{% endfor %}</span>
          <strong>4.9</strong>
          <span>· 2,400+ verified reviews</span>
        </div>

        <div>
          <div class="buy-title-row">
            <h1>{{ product.title }}</h1>
            <span class="buy-tag"><span class="dot"></span>New</span>
          </div>
          <p class="buy-summary" style="margin-top:14px;">For athletes, runners, padel players and anyone who sweats for real. IONIQ replaces the electrolyte, the nootropic, the magnesium and the recovery drink with one sachet — calibrated to what the body actually loses, so your hydration, recovery and clean energy stay locked in. No caffeine. No sugar. No flavoured water.</p>
        </div>

        <div class="buy-meta">
          <span><strong>750mg</strong> sodium</span><span class="sep"></span>
          <span><strong>200mg</strong> potassium</span><span class="sep"></span>
          <span><strong>50mg</strong> magnesium</span><span class="sep"></span>
          <span>30 sachets</span>
        </div>

        {% form 'product', product, id: 'product-form-{{ section.id }}' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id | default: product.variants.first.id }}">
          {% if product.variants.size > 1 %}
            <div>
              <div class="section-label">{{ product.options.first }}</div>
              <div class="flavors">
                {% for variant in product.variants %}
                  <button type="button" class="flavor{% if variant == product.selected_or_first_available_variant %} is-selected{% endif %}{% unless variant.available %} is-soon{% endunless %}" data-variant-id="{{ variant.id }}">
                    {% unless variant.available %}<span class="ribbon">Soon</span>{% endunless %}
                    <span class="swatch" style="background: linear-gradient(160deg, #F4ECDB, #B0B8A4);"></span>
                    <span class="nm">{{ variant.title }}</span>
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          <div class="atc-row">
            <div class="qty">
              <button type="button" data-qty="-1">-</button>
              <input type="number" name="quantity" value="1" min="1" style="width:32px;text-align:center;border:none;background:transparent;font-family:var(--font-display);font-weight:800;font-size:15px;">
              <button type="button" data-qty="+1">+</button>
            </div>
            <button type="submit" class="atc-btn">
              <span>Add to cart</span>
              <span>{{ product.price | money_without_trailing_zeros }}</span>
            </button>
          </div>
        {% endform %}

        <div class="atc-meta">Tax included. <a href="#">Shipping calculated at checkout.</a> 60-day risk-free guarantee — refund any unused box.</div>

        <details class="acc" open>
          <summary>Key benefits</summary>
          <div class="body">
            <ul style="margin:0; padding-left:18px; list-style:disc;">
              <li><strong>Sustained energy</strong> — from a full mineral charge, not stimulants.</li>
              <li><strong>Mental clarity &amp; focus</strong> — Cognizin® citicoline, L-tyrosine, Rhodiola.</li>
              <li><strong>Faster recovery &amp; reduced inflammation</strong> — magnesium, ALCAR, taurine.</li>
              <li><strong>Longevity support</strong> — pH 12 alkaline, antioxidant hydroxyl ions.</li>
              <li><strong>Hydration that reaches your cells</strong> — bamboo salt + 70+ trace minerals.</li>
            </ul>
          </div>
        </details>
        <details class="acc">
          <summary>How to use</summary>
          <div class="body">
            <p>Tear one sachet, pour into 500ml of cold water, stir until fully dissolved. Drink in the morning — ideally before your first coffee. On training days, drink one pre-workout and one within 30 min of finishing.</p>
          </div>
        </details>
        <details class="acc">
          <summary>Full ingredient list</summary>
          <div class="body">
            <p>9× fire-roasted bamboo salt (sodium, potassium chloride, 70+ trace minerals, hydroxyl ions), magnesium citrate, Cognizin® citicoline, L-tyrosine, Rhodiola rosea (3% rosavins), ALCAR (acetyl-L-carnitine), taurine, natural lemon flavour, organic stevia leaf extract. No fillers, no proprietary blends, no artificial colours, no artificial flavours.</p>
          </div>
        </details>
        <details class="acc">
          <summary>Nutritional info</summary>
          <div class="body">
            <p>Per sachet (5,000mg total active): Energy 8 kcal · Sodium 750mg · Potassium 200mg · Magnesium 50mg · Cognizin® 250mg · L-Tyrosine 500mg · Rhodiola 200mg · ALCAR 300mg · Taurine 500mg · Total sugars 0mg · Caffeine 0mg.</p>
          </div>
        </details>
        <details class="acc">
          <summary>Shipping &amp; returns</summary>
          <div class="body">
            <p>Free shipping on all subscriptions. Orders typically deliver in 2-4 business days. 60-day risk-free guarantee on every order — if it doesn't work for you, send the box back for a full refund. No restocking fees, ever.</p>
          </div>
        </details>
      </div>
    </div>
  </div>
</section>
<script>
  document.querySelectorAll('.thumb').forEach(t => {
    t.addEventListener('click', () => {
      document.querySelectorAll('.thumb').forEach(x => x.classList.remove('is-active'));
      t.classList.add('is-active');
      const heroImg = document.querySelector('[id^="hero-img-"]');
      if (heroImg) heroImg.src = t.dataset.img;
    });
  });
  document.querySelectorAll('.flavor:not(.is-soon)').forEach(f => {
    f.addEventListener('click', () => {
      document.querySelectorAll('.flavor').forEach(x => x.classList.remove('is-selected'));
      f.classList.add('is-selected');
      const idField = document.querySelector('[name="id"]');
      if (idField) idField.value = f.dataset.variantId;
    });
  });
  document.querySelectorAll('.qty button').forEach(b => {
    b.addEventListener('click', () => {
      const input = b.parentNode.querySelector('input');
      input.value = Math.max(1, parseInt(input.value) + parseInt(b.dataset.qty));
    });
  });
</script>
{% endif %}
{% schema %}
{ "name": "Main product", "enabled_on": { "templates": ["product"] } }
{% endschema %}